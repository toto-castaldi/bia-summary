{
  "name": "bia-summary",
  "version": "0.1.0",
  "type": "module",
  "description": "CLI tool to generate structured Italian summaries from BIA report PDFs",
  "bin": {
    "bia-summary": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx --env-file=.env src/cli.ts",
    "build": "tsup src/cli.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "start": "node --env-file=.env dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toto-castaldi/bia-summary.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/toto-castaldi/bia-summary/issues"
  },
  "homepage": "https://github.com/toto-castaldi/bia-summary#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "commander": "^14.0.3",
    "ora": "^9.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
